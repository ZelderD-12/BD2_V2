.PHONY: dev stop clean start db-export db-import docker-up docker-down docker-restart

# Detectar sistema operativo
ifeq ($(OS),Windows_NT)
    KILL_BUN = @taskkill /F /IM bun.exe 2>nul || true
    KILL_NODE = @taskkill /F /IM node.exe 2>nul || true
    DOWNLOADS = C:/Users/$(USERNAME)/Downloads
    IMPORT_DIR = sql/import
else
    KILL_BUN = @pkill bun 2>/dev/null || true
    KILL_NODE = @pkill node 2>/dev/null || true
    DOWNLOADS = $(HOME)/Downloads
    IMPORT_DIR = sql/import
endif

DB_CONTAINER = clinica_sqlserver
DB_USER = sa
DB_PASSWORD = "ClinicaDBgrupo3#"
DB_NAME = ClinicaF
SQLCMD = /opt/mssql-tools18/bin/sqlcmd
DATE = $(shell powershell -Command "Get-Date -Format 'yyyyMMdd_HHmmss'")

dev:
	@echo 🧹 Limpiando procesos anteriores...
	$(KILL_BUN)
	$(KILL_NODE)
	@echo 🚀 Iniciando servicios...
	@bun run dev

stop:
	@echo 🔴 Deteniendo servicios...
	$(KILL_BUN)
	$(KILL_NODE)
	@echo ✅ Servicios detenidos

start: stop dev

# Exportar base de datos
db-export:
	@echo 📦 Exportando base de datos $(DB_NAME)...
	@docker exec -it $(DB_CONTAINER) $(SQLCMD) -S localhost -U $(DB_USER) -P $(DB_PASSWORD) -C -Q "BACKUP DATABASE [$(DB_NAME)] TO DISK = N'/var/opt/mssql/backup/$(DB_NAME).bak'"
	@echo ✅ Backup creado en el contenedor
	@mkdir -p sql/export 2>nul || true
	@docker cp $(DB_CONTAINER):/var/opt/mssql/backup/$(DB_NAME).bak "./sql/export/$(DB_NAME)_$(DATE).bak"
	@echo ✅ Backup guardado en: sql/export/$(DB_NAME)_$(DATE).bak

# Importar base de datos desde sql/import/
db-import:
	@echo 📥 Buscando archivo .bak en $(IMPORT_DIR)...
	@if not exist "$(IMPORT_DIR)\\*.bak" ( \
		echo ❌ No se encontró ningún archivo .bak en $(IMPORT_DIR) & \
		echo 💡 Coloca tu archivo .bak en la carpeta $(IMPORT_DIR) & \
		exit 1 \
	)
	@echo 📋 Copiando archivo al contenedor...
	@for %%f in ("$(IMPORT_DIR)\\*.bak") do @docker cp "%%f" $(DB_CONTAINER):/var/opt/mssql/backup/restore.bak
	@echo 🔄 Restaurando base de datos $(DB_NAME)...
	@docker exec -it $(DB_CONTAINER) $(SQLCMD) -S localhost -U $(DB_USER) -P $(DB_PASSWORD) -C -Q "RESTORE DATABASE [$(DB_NAME)] FROM DISK = N'/var/opt/mssql/backup/restore.bak' WITH REPLACE, RECOVERY"
	@echo ✅ Base de datos restaurada exitosamente

# Importar desde Downloads
db-import-downloads:
	@echo 📥 Restaurando desde Downloads...
	@docker cp "$(DOWNLOADS)/ClinicaF.bak" $(DB_CONTAINER):/var/opt/mssql/backup/restore.bak
	@docker exec -it $(DB_CONTAINER) $(SQLCMD) -S localhost -U $(DB_USER) -P $(DB_PASSWORD) -C -Q "RESTORE DATABASE [$(DB_NAME)] FROM DISK = N'/var/opt/mssql/backup/restore.bak' WITH REPLACE, RECOVERY"
	@echo ✅ Base de datos restaurada exitosamente

# Docker - levanta SQL Server + Backend en contenedores
docker-up:
	@docker-compose up -d --build
	@echo ⏳ Esperando que el backend inicie...
	@timeout /t 5 /nobreak >nul
	@echo ✅ Backend en http://localhost:${BACKEND_PORT:-8080}
	@echo ✅ SQL Server en localhost:${SQLSERVER_PORT:-1436}

# Docker + frontend local (flujo completo)
docker-dev: docker-up
	@echo 🚀 Iniciando frontend local...
	@bun run --filter frontend dev

docker-down:
	@docker-compose down

docker-restart: docker-down docker-up

# Frontend local (asume que el backend ya está en Docker o en línea)
dev-frontend:
	@echo 🚀 Iniciando frontend...
	@bun run --filter frontend dev